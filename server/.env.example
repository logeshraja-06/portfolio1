PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB Connection String (Render / MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/portfolio?retryWrites=true&w=majority

# Gmail SMTP Authentication Details
# To use Gmail, enable 2-Step Verification on Google and generate an "App Password"
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-google-app-password

# Email to receive contact inquiries (defaults to EMAIL_USER if left empty)
RECEIVER_EMAIL=your-recipient-email@gmail.com
